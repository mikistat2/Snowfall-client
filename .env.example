# --- API location ---
# Leave UNSET for local development (the Vite dev server proxies /api and
# /socket.io to localhost:4000). For separate hosting (Vercel client +
# Render API), set this to the API's public URL — no trailing slash:
# VITE_API_URL=https://snowfall-api.onrender.com
VITE_API_URL=

# --- Phone/IP camera option (LAN-only feature) ---
# Only works when the SERVER runs inside the gym's network (local/on-prem
# install). Leave unset for cloud deployments — the monitor uses the webcam.
# VITE_ENABLE_IP_CAMERA=true
VITE_ENABLE_IP_CAMERA=
